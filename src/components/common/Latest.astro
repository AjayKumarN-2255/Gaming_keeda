---
const { title, image, url } = Astro.props;
---

<div class="border-b border-white last:border-0">
    <a
        href={url}
        class="group flex items-start gap-4 py-4 px-1"
    >
        <!-- IMAGE -->
        <div
            class="w-[100px] h-[65px] flex-shrink-0 overflow-hidden rounded-md"
        >
            <img
                src={image}
                alt={title}
                class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-110"
            />
        </div>

        <!-- TEXT -->
        <div class="flex flex-col">
            <h4 class="text-white text-[14px] font-bold leading-[1.3]">
                {title}
            </h4>
        </div>
    </a>
</div>