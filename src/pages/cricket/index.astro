---

<Layout>
    <div class="w-full flex flex-col p-6 xl:flex-row gap-4">
        <div class="flex-1 flex flex-col gap-10">
            <div class="w-full rounded-lg bg-secondary min-h-52 p-5">
                <h2 class="font-bold text-white mb-2">{archiveData?.title}</h2>
                <div set:html={renderBlocks(archiveData?.editorBlocks)} />
            </div>
            <div
                class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
            >
                {
                    cricketNews.map((news) => (
                        <PostCard
                            title={news.title}
                            date={news.date}
                            image={news.image}
                            url={news.url}
                        />
                    ))
                }
            </div>
        </div>
        <div
            class="xl:w-[325px] w-full max-h-[1060px] bg-secondary rounded-lg p-[10px]"
        >
            <h3 class="font-bold text-highlight">LATEST NEWS</h3>
            <hr class="border-white border-[1.5px] my-2 font-bold" />
            {
                sidebarNews.map((news) => (
                    <Latest
                        title={news.title}
                        image={news.image}
                        url={news.url}
                    />
                ))
            }
        </div>
    </div>
</Layout>
